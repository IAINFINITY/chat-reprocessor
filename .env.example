# URL base do seu Chatwoot (sem barra final)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# Token tecnico (api_access_token)
CHATWOOT_API_ACCESS_TOKEN=troque-aqui

# Prisma + Supabase Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Porta local do backend
PORT=3333

# OpenAI (opcional para enriquecer audio/imagem)
OPENAI_API_KEY=troque-aqui
ENABLE_MEDIA_AI=false

# Supabase (necessario para auth e checagens de pausa)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=troque-aqui
SUPABASE_SERVICE_ROLE_KEY=troque-aqui

# Callback do Error Trigger do n8n
N8N_ERROR_CALLBACK_SECRET=troque-aqui

# API do n8n
N8N_API_BASE_URL=https://workflows-n8n.iainfinity.app
N8N_API_KEY=troque-aqui

# Auth fixa (backend session + allowlist no Supabase)
AUTH_ENABLED=true
AUTH_SESSION_SECRET=troque-por-um-segredo-forte
