# URL base do seu Chatwoot (sem barra final)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# Token tecnico (api_access_token)
CHATWOOT_API_ACCESS_TOKEN=troque-aqui

# Porta local do middleware
PORT=3000

# Clientes habilitados para o fluxo novo de reprocessamento (separados por virgula)
REPROCESS_CLIENTS=n8n

# Exemplo de cliente: N8N
CLIENT_N8N_NAME=N8N
CLIENT_N8N_REPROCESS_WEBHOOK=https://seu-dominio/webhook/n8n-reprocess
# Opcional: secret enviado em header para o webhook
CLIENT_N8N_WEBHOOK_SECRET=troque-aqui
# Opcional: nome do header de secret
CLIENT_N8N_WEBHOOK_SECRET_HEADER=x-reprocess-secret
# Opcional: ajuda na deteccao automatica quando o client nao for enviado
CLIENT_N8N_CHATWOOT_ACCOUNT_IDS=12
# Opcional: nome do payload builder (default, n8n)
CLIENT_N8N_PAYLOAD_BUILDER=n8n
