# URL base do seu Chatwoot (sem barra final)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# Token tecnico (api_access_token)
CHATWOOT_API_ACCESS_TOKEN=troque-aqui

# OpenAI (opcional para enriquecer audio/imagem)
OPENAI_API_KEY=troque-aqui
ENABLE_MEDIA_AI=false
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_VISION_MODEL_NAME=gpt-4o-mini
OPENAI_AUDIO_MODEL_NAME=gpt-4o-mini-transcribe
MEDIA_AUDIO_PROMPT_PATH=prompts/media_audio_prompt.txt
MEDIA_IMAGE_PROMPT_PATH=prompts/media_image_prompt.txt

# Timeout/retry global para todos os webhooks (pode sobrescrever por cliente)
REPROCESS_WEBHOOK_TIMEOUT_MS=30000
REPROCESS_WEBHOOK_RETRY_COUNT=2
