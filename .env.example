# URL base do seu Chatwoot (sem barra final)
CHATWOOT_BASE_URL=https://app.chatwoot.com

# Token tecnico (api_access_token)
CHATWOOT_API_ACCESS_TOKEN=troque-aqui

# OpenAI (opcional para enriquecer audio/imagem)
OPENAI_API_KEY=troque-aqui
ENABLE_MEDIA_AI=false
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_VISION_MODEL_NAME=gpt-4o-mini
OPENAI_AUDIO_MODEL_NAME=gpt-4o-mini-transcribe
MEDIA_AUDIO_PROMPT_PATH=prompts/media_audio_prompt.txt
MEDIA_IMAGE_PROMPT_PATH=prompts/media_image_prompt.txt

# Timeout/retry global para todos os webhooks (pode sobrescrever por cliente)
REPROCESS_WEBHOOK_TIMEOUT_MS=30000
REPROCESS_WEBHOOK_RETRY_COUNT=2

# Supabase (opcional, para checar se contato esta pausado antes de enviar ao n8n)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=troque-aqui
PAUSE_CHECK_TIMEOUT_MS=8000
PAUSE_CHECK_SAMPLE_LIMIT=200
REPROCESS_PAUSE_DEFAULT_SCHEMA=public
REPROCESS_PAUSE_AUTO_DETECT_TABLE=true
REPROCESS_PAUSE_TABLE_SUFFIX=pausar

# Callback do Error Trigger do n8n (opcional, recomendado para diagnostico real)
N8N_ERROR_CALLBACK_SECRET=troque-aqui
N8N_ERROR_CALLBACK_HEADER=x-n8n-error-secret

# API do n8n (opcional, recomendado para rastrear progresso real da execucao)
N8N_API_BASE_URL=https://workflows-n8n.iainfinity.app
N8N_API_KEY=troque-aqui
N8N_API_TIMEOUT_MS=30000
N8N_RECONCILE_ENABLED=true
N8N_RECONCILE_DELAYS_MS=5000,15000,30000
N8N_EXECUTION_LOOKBACK_LIMIT=40

# Persistencia local de eventos n8n (sem banco)
N8N_EVENT_STORE_PATH=data/n8n-events.json
N8N_EVENT_STORE_MAX_EVENTS=500

# Auth temporario para ambientes publicados (ex.: Vercel)
TEMP_AUTH_ENABLED=true
TEMP_AUTH_USERNAME=seu_usuario
TEMP_AUTH_PASSWORD=sua_senha_forte
