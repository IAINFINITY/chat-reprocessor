generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthRole {
  admin
  operator
}

enum ReprocessStatus {
  pending
  running
  success
  warning
  error
  canceled
  timeout
}

enum N8nEventType {
  error
  status
  execution
}

model AllowedUser {
  id          String    @id @default(cuid())
  email       String    @unique
  active      Boolean   @default(true)
  role        AuthRole  @default(operator)
  displayName String?   @map("display_name")
  notes       String?
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([active, role], map: "idx_reprocess_allowed_users_active_role")
  @@map("REPROCESSAMENTO - allowed_users")
}

model AuthSession {
  sid        String    @id
  userId     String?   @map("user_id")
  email      String
  role       AuthRole  @default(operator)
  ip         String?
  userAgent  String?   @map("user_agent")
  issuedAt   DateTime  @default(now()) @map("issued_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([email], map: "idx_reprocess_auth_sessions_email")
  @@index([expiresAt], map: "idx_reprocess_auth_sessions_expires_at")
  @@index([revokedAt], map: "idx_reprocess_auth_sessions_revoked_at")
  @@map("REPROCESSAMENTO - auth_sessions")
}

model AuthAuditEvent {
  id           String   @id @default(cuid())
  eventType    String   @map("event_type")
  outcome      String
  reason       String?
  email        String?
  role         String?
  sessionId    String?  @map("session_id")
  ip           String?
  userAgent    String?  @map("user_agent")
  requestPath  String?  @map("request_path")
  requestMethod String? @map("request_method")
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt], map: "idx_reprocess_auth_audit_events_created_at")
  @@index([eventType, createdAt], map: "idx_reprocess_auth_audit_events_event_type_created_at")
  @@index([email, createdAt], map: "idx_reprocess_auth_audit_events_email_created_at")
  @@map("REPROCESSAMENTO - auth_audit_events")
}

model N8nEvent {
  id             String       @id @default(cuid())
  eventType      N8nEventType @map("event_type")
  category       String
  title          String
  likelyCause    String?      @map("likely_cause")
  suggestion     String?
  workflowName   String?      @map("workflow_name")
  workflowId     String?      @map("workflow_id")
  executionId    String?      @map("execution_id")
  executionUrl   String?      @map("execution_url")
  failedNode     String?      @map("failed_node")
  requestId      String?      @map("request_id")
  conversationId String?      @map("conversation_id")
  client         String?
  status         String?
  nodesExecuted  Int?         @map("nodes_executed")
  n8nHttpCode    String?      @map("n8n_http_code")
  errorMessage   String?      @map("error_message")
  errorDescription String?    @map("error_description")
  upstreamMessages Json?      @map("upstream_messages")
  duplicateCount Int          @default(1) @map("duplicate_count")
  source         String?
  receivedAt     DateTime     @default(now()) @map("received_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([receivedAt], map: "idx_reprocess_n8n_events_received_at")
  @@index([requestId, receivedAt], map: "idx_reprocess_n8n_events_request_id_received_at")
  @@index([conversationId, receivedAt], map: "idx_reprocess_n8n_events_conversation_id_received_at")
  @@index([client, receivedAt], map: "idx_reprocess_n8n_events_client_received_at")
  @@map("REPROCESSAMENTO - n8n_events")
}

model ReprocessExecution {
  id                 String          @id @default(cuid())
  requestId          String?         @unique @map("request_id")
  client             String
  accountId          Int?            @map("account_id")
  conversationId     Int?            @map("conversation_id")
  contactId          Int?            @map("contact_id")
  phone              String?
  status             ReprocessStatus @default(pending)
  durationMs         Int?            @map("duration_ms")
  webhookUrl         String?         @map("webhook_url")
  payloadPreview     Json?           @map("payload_preview")
  webhookResponse    Json?           @map("webhook_response")
  errorCode          String?         @map("error_code")
  errorMessage       String?         @map("error_message")
  n8nExecutionId     String?         @map("n8n_execution_id")
  n8nWorkflowName    String?         @map("n8n_workflow_name")
  startedAt          DateTime?       @map("started_at")
  finishedAt         DateTime?       @map("finished_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@index([client, createdAt], map: "idx_reprocess_executions_client_created_at")
  @@index([conversationId, createdAt], map: "idx_reprocess_executions_conversation_created_at")
  @@index([status, createdAt], map: "idx_reprocess_executions_status_created_at")
  @@map("REPROCESSAMENTO - reprocess_executions")
}

model QueueItem {
  id             String          @id @default(cuid())
  requestId      String?         @map("request_id")
  client         String
  conversationId Int?            @map("conversation_id")
  status         ReprocessStatus @default(pending)
  payload        Json?
  enqueuedAt     DateTime        @default(now()) @map("enqueued_at")
  claimedAt      DateTime?       @map("claimed_at")
  finishedAt     DateTime?       @map("finished_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([status, enqueuedAt], map: "idx_reprocess_queue_items_status_enqueued_at")
  @@index([client, enqueuedAt], map: "idx_reprocess_queue_items_client_enqueued_at")
  @@map("REPROCESSAMENTO - queue_items")
}

model ReprocessCompany {
  id                 String   @id @default(cuid())
  nome               String
  nomeNormalizado    String   @unique @map("nome_normalizado")
  urlWebhook         String   @map("url_webhook")
  tabela             String
  chatwootAccountIds Json     @default("[]") @map("chatwoot_account_ids")
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([ativo, nomeNormalizado], map: "idx_reprocess_companies_ativo_nome_normalizado")
  @@map("REPROCESSAMENTO - companies")
}
