{
  "name": "chatwoot-reprocess-helper",
  "version": "0.1.0",
  "description": "Facilitador para reprocessamento de conversas Chatwoot via API oficial",
  "main": "src/app/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/app/server.js",
    "dev": "node --watch src/app/server.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@supabase/supabase-js": "^2.105.4",
    "openai": "^4.104.0",
    "pg": "^8.21.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "engines": {
    "node": "24.x"
  }
}
